# XHTTPRelayECO v3.0 Ultimate - Environment Variables
# Copy this file to .env.local and configure your settings

# Target upstream server (required)
TARGET_BASE=http://vercel.parsashonam.sbs:2096

# Relay endpoint path (required)
RELAY_PATH=/p4r34m

# Authentication key (optional, but recommended for production)
# Must be at least 16 characters long
# Generate with: openssl rand -hex 32
RELAY_KEY=

# Node environment
NODE_ENV=production

# Debug mode (set to "true" for verbose logging)
DEBUG=false